# Smart Digital Locker System - Sample Environment File
# This file contains sample values - for production, generate strong secrets!

PORT=5000
NODE_ENV=development

# MongoDB Configuration - Local Development
MONGODB_URI=mongodb://localhost:27017/smart-digital-locker

# For MongoDB Atlas (Cloud) - uncomment and update with your credentials
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/smart-digital-locker?retryWrites=true&w=majority

# JWT Configuration
# Change this to a strong random string in production!
# Generate: openssl rand -base64 32
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_minimum_32_chars
JWT_EXPIRE=7d

# AES-256 Encryption Key (64 hex characters = 32 bytes = 256 bits)
# Generate: openssl rand -hex 32
# IMPORTANT: This key determines file security - keep it secret and safe!
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# File Upload Configuration (in bytes)
MAX_FILE_SIZE=104857600
MAX_TOTAL_SIZE=1073741824
